{
  "name": "@freellmapi/shared",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/types.js",
  "types": "./dist/types.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types.d.ts",
      "default": "./dist/types.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "default": "./dist/types.js"
    },
    "./types.js": {
      "types": "./dist/types.d.ts",
      "default": "./dist/types.js"
    },
    "./validate-username": {
      "types": "./dist/validate-username.d.ts",
      "default": "./dist/validate-username.js"
    },
    "./validate-username.js": {
      "types": "./dist/validate-username.d.ts",
      "default": "./dist/validate-username.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch --preserveWatchOutput"
  },
  "files": ["dist"],
  "dependencies": {
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "typescript": "^5.8.3"
  }
